# ─────────────────────────────────────────────
# Google Maps JavaScript API — 前端用 key
# Vercel → Project → Settings → Environment Variables
# 變數名:NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
# ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────
# 網站公開 URL — 用來組 Open Graph / Twitter 圖片的絕對網址
# 未設定時會 fallback 到 VERCEL_URL,再不然是 http://localhost:3000
# 例如:https://our-family-journeys.vercel.app
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
